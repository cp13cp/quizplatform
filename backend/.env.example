# Copy to .env and adjust
# Local: mongodb://localhost:27017  |  Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_URI=mongodb://localhost:27017
DB_NAME=quizapp
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRE_MINUTES=1440
# First admin bootstrapped on startup
ADMIN_EMAIL=admin@quiz.com
ADMIN_PASSWORD=admin123
# Comma separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173
# Public frontend URL used in password-reset links
FRONTEND_URL=http://localhost:5173
# SMTP settings for password-reset emails
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-username
EMAIL_PASSWORD=your-smtp-password
EMAIL_FROM=no-reply@example.com
# Recommended for Render: SendGrid uses HTTPS while Gmail SMTP may be blocked.
SENDGRID_API_KEY=your-sendgrid-api-key
